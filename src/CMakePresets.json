{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "dev",
            "displayName": "Dev (Ninja via $CMAKE_GENERATOR if available, else platform default generator)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "sanitize",
            "displayName": "Sanitize (ASan + UBSan, non-MSVC)",
            "inherits": "base",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CONTEXT_SANITIZE": "ON"
            }
        },
        {
            "name": "tsan",
            "displayName": "TSan (ThreadSanitizer, non-MSVC; mutually exclusive with sanitize)",
            "inherits": "base",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CONTEXT_TSAN": "ON"
            }
        },
        {
            "name": "spikes",
            "displayName": "Spikes (opt-in M0 spike targets; Release; vcpkg toolchain via $env{VCPKG_ROOT})",
            "inherits": "base",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CONTEXT_BUILD_SPIKES": "ON",
                "VCPKG_MANIFEST_FEATURES": "spikes"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "configuration": "Release"
        },
        {
            "name": "sanitize",
            "configurePreset": "sanitize",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "tsan",
            "configurePreset": "tsan",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "spikes",
            "configurePreset": "spikes",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "configuration": "Release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "sanitize",
            "configurePreset": "sanitize",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan",
            "configurePreset": "tsan",
            "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "output": { "outputOnFailure": true }
        },
        {
            "name": "spikes",
            "configurePreset": "spikes",
            "configuration": "Release",
            "output": { "outputOnFailure": true }
        }
    ]
}
