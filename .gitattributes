# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Windows-native files keep CRLF on checkout.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
