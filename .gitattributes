# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Windows-native files keep CRLF on checkout.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Signed-fetch trust fixtures (R-SEC-009): the SSH signature is over the artifact's
# EXACT bytes, so these must never be EOL-normalized (a CRLF rewrite on a Windows
# checkout would flip the bytes and break verification). Pin the whole fixtures tree
# and every detached-signature file as byte-exact.
tools/tests/fixtures/** -text
*.sig -text

# M5-F6 a11y coverage manifest (R-A11Y-001): an append-only shared anchor (one JSON object per
# line). Concurrent M5 panel waves each append their panel entry; union-merge makes disjoint appends
# conflict-free (a panel is "covered" only once it appears here AND in registered_panels() —
# tools/a11y_scan.py cross-checks the two).
src/editor/gui/a11y/coverage.manifest.jsonl merge=union

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
