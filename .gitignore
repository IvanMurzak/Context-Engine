# Build output
build/
build-*/
out/
cmake-build-*/
# The `build/` rule above ignores any directory named `build` (CMake output dirs like src/build/).
# Re-include the src/editor/build/ SOURCE module (the build orchestration core, task a05) — it is
# engine source, not build output, and only ever contains committed .h/.cpp/CMakeLists/README/tests.
!src/editor/build/

# vcpkg
vcpkg_installed/

# npm (future)
node_modules/

# Generated by tools/check_licenses.py
sbom.json

# Benchmark corpora + results (generated by bench/gen_corpus.py / bench/harness.py;
# CI archives results as artifacts, never in git)
bench/corpora/
bench/results/

# Editor session / control state (daemon + GUI): the gitignored per-project control dir holding
# instance.json (R-ARCH-005 discovery), the index, the crash-recovery intent log, and the GUI
# session undo/redo journal session.json (R-FILE-006 / R-HUX-001 — ephemeral session state, never
# authored file state).
.editor/

# IDE / editor
.vs/
.vscode/
.idea/
*.swp
CMakeUserPresets.json

# OS noise
.DS_Store
Thumbs.db

# Python test/tooling caches
__pycache__/
.pytest_cache/
